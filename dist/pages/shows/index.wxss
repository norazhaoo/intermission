.shows-page{background-color:#fff9ed;min-height:100vh}.shows-header{padding:32rpx}.shows-header__title{color:#5d000a;display:block;font-size:48rpx;font-weight:700;margin-bottom:24rpx}.shows-search{align-items:center;background-color:#f2e7d4;border-radius:24rpx;display:flex;padding:16rpx 24rpx}.shows-search__icon{font-size:32rpx;margin-right:12rpx}.shows-search__input{color:#1f1c0b;flex:1;font-size:26rpx}.shows-search__placeholder{color:#8b716f}.shows-list{height:calc(100vh - 280rpx);padding:0 32rpx}.show-item{border-bottom:2rpx solid #ebe2c8;display:flex;gap:20rpx;padding:20rpx 0}.show-item__poster{border-radius:8rpx;flex-shrink:0;height:140rpx;width:100rpx}.show-item__info{display:flex;flex:1;flex-direction:column;justify-content:center}.show-item__title{color:#5d000a;display:block;font-size:28rpx;font-weight:700;margin-bottom:6rpx}.show-item__composer{color:#8b716f;display:block;font-size:24rpx}.show-item__badge{align-self:flex-start;background-color:#81131a;border-radius:16rpx;margin-top:8rpx;padding:4rpx 16rpx}.show-item__badge text{color:#fff;font-size:18rpx}.shows-cta{margin-top:32rpx;padding:32rpx;text-align:center}.shows-cta__title{color:#5d000a;display:block;font-size:30rpx;margin-bottom:8rpx}.shows-cta__text{color:#8b716f;display:block;font-size:24rpx}