.tickets-page{background-color:#fff9ed;min-height:100vh}.tickets-header{padding:32rpx}.tickets-header__title{color:#5d000a;display:block;font-size:48rpx;font-weight:700}.tickets-header__subtitle{color:#8b716f;display:block;font-size:24rpx;margin-top:8rpx}.tickets-actions{display:flex;flex-direction:column;gap:24rpx;padding:0 32rpx}.ticket-action{align-items:center;display:flex;gap:24rpx;padding:32rpx;transition:transform .15s ease}.ticket-action__icon-circle{align-items:center;background:linear-gradient(135deg,#5d000a,#81131a);border-radius:48rpx;display:flex;flex-shrink:0;height:96rpx;justify-content:center;width:96rpx}.ticket-action__icon{font-size:40rpx}.ticket-action__text{flex:1}.ticket-action__title{color:#5d000a;display:block;font-size:30rpx;font-weight:700;margin-bottom:8rpx}.ticket-action__subtitle{color:#8b716f;display:block;font-size:24rpx}