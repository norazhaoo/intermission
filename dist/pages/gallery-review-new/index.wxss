.review-page{background-color:#fff9ed;min-height:100vh}.review-act-header{padding:48rpx 32rpx;text-align:center}.review-act-header__label{color:#d4af37;display:block;font-size:22rpx;letter-spacing:6rpx;margin-bottom:8rpx}.review-act-header__title{color:#fff;display:block;font-size:40rpx;font-style:italic}.review-show-info{margin:24rpx 32rpx;padding:20rpx 24rpx;text-align:center}.review-section{padding:24rpx 32rpx}.review-section__title{color:#5d000a;display:block;font-size:30rpx;font-weight:700;margin-bottom:12rpx}.review-section__desc{color:#8b716f;display:block;font-size:24rpx;margin-bottom:20rpx}.playbill-upload{align-items:center;border:4rpx dashed #dfbfbd;border-radius:16rpx;display:flex;height:360rpx;justify-content:center;margin:0 auto;overflow:hidden;width:280rpx}.playbill-upload__image{height:100%;width:100%}.playbill-upload__placeholder{align-items:center;display:flex;flex-direction:column;gap:12rpx}.score-slider{margin-bottom:32rpx}.score-slider__header{align-items:center;display:flex;justify-content:space-between;margin-bottom:4rpx}.score-slider__label{color:#5d000a;font-size:22rpx}.score-slider__level{color:#d4af37;font-size:20rpx}.score-slider__subtitle{color:#8b716f;display:block;font-size:20rpx;margin-bottom:12rpx}.review-notes{background-color:#f2e7d4;border-radius:16rpx;box-sizing:border-box;color:#1f1c0b;font-size:26rpx;line-height:1.6;min-height:200rpx;padding:24rpx;width:100%}.review-notes__placeholder{color:#8b716f;font-style:italic}