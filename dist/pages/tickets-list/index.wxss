.tickets-list-page{background-color:#fff9ed;min-height:100vh;padding:32rpx}.tickets-section{margin-bottom:16rpx}.tickets-section__title{color:#5d000a;display:block;font-size:36rpx;font-weight:700;margin-bottom:24rpx}.tickets-section__empty{color:#8b716f;display:block;font-size:24rpx;padding:32rpx 0}.ticket-card{margin-bottom:24rpx;overflow:hidden}.ticket-card--past{opacity:.65}.ticket-card__header{padding:24rpx}.ticket-card__show{color:#5d000a;display:block;font-size:30rpx;font-weight:700;text-transform:uppercase}.ticket-card__theater{color:#8b716f;display:block;font-size:22rpx;margin-top:8rpx}.ticket-card__details{padding:20rpx 24rpx}.ticket-card__row{display:flex;justify-content:space-between;padding:8rpx 0}.ticket-card__label{color:#8b716f;font-size:20rpx}.ticket-card__value{color:#1f1c0b;font-size:24rpx}