.detail-page{background-color:#fff9ed;min-height:100vh}.detail-hero{height:480rpx;overflow:hidden;position:relative}.detail-hero__image{height:100%;width:100%}.detail-hero__overlay{background:linear-gradient(transparent 40%,rgba(93,0,10,.8));bottom:0;left:0;position:absolute;right:0;top:0}.detail-hero__content{bottom:32rpx;left:32rpx;position:absolute;right:32rpx}.detail-hero__title{color:#fff;display:block;font-size:48rpx;font-style:italic;font-weight:700;text-shadow:0 4rpx 8rpx rgba(0,0,0,.3)}.detail-hero__badge{background-color:#81131a;border-radius:16rpx;display:inline-block;margin-top:12rpx;padding:6rpx 20rpx}.detail-info{margin:24rpx 32rpx;padding:24rpx}.detail-info__row{border-bottom:2rpx solid #ebe2c8;display:flex;justify-content:space-between;padding:12rpx 0}.detail-info__row:last-child{border-bottom:none}.detail-info__label{color:#8b716f;font-size:20rpx}.detail-info__value{color:#1f1c0b;font-size:24rpx;text-align:right}.detail-section{padding:24rpx 32rpx}.detail-section__title{color:#5d000a;display:block;font-size:32rpx;font-weight:700;margin-bottom:20rpx}.detail-section__text{color:#4c4733;display:block;font-size:26rpx;line-height:1.6}.cast-grid{display:grid;grid-gap:20rpx;gap:20rpx;grid-template-columns:repeat(4,1fr)}.cast-item{align-items:center;display:flex;flex-direction:column;text-align:center}.cast-item__avatar{align-items:center;background-color:#81131a;border-radius:48rpx;display:flex;height:96rpx;justify-content:center;margin-bottom:8rpx;overflow:hidden;width:96rpx}.cast-item__photo{height:100%;width:100%}.cast-item__initials{color:#fff;font-size:24rpx;font-weight:700}.cast-item__name{color:#1f1c0b;display:block;font-size:20rpx}.cast-item__role{color:#8b716f;display:block;font-size:18rpx;margin-top:4rpx}.award-item{align-items:flex-start;display:flex;padding:12rpx 0}.history-item{border-bottom:2rpx solid #ebe2c8;display:flex;gap:16rpx;padding:12rpx 0}.history-item__year{color:#5d000a;flex-shrink:0;font-size:28rpx;font-weight:700;width:80rpx}.history-item__desc{color:#4c4733;flex:1;font-size:24rpx}.audience-review{background-color:#f8edd9;border-radius:16rpx;margin-bottom:16rpx;padding:24rpx}.audience-review__stars{margin-bottom:12rpx}.audience-review__text{color:#4c4733;display:block;font-size:24rpx;font-style:italic;line-height:1.5;margin-bottom:16rpx}.audience-review__author{align-items:center;display:flex;gap:12rpx}.audience-review__avatar{align-items:center;background-color:#81131a;border-radius:24rpx;display:flex;height:48rpx;justify-content:center;width:48rpx}.audience-review__name{color:#1f1c0b;display:block;font-size:22rpx}.audience-review__date{color:#8b716f;display:block;font-size:18rpx}