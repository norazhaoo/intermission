.calendar-page{background-color:#fff9ed;min-height:100vh}.calendar-header{padding:32rpx}.calendar-header__title{color:#5d000a;display:block;font-size:48rpx;font-weight:700}.calendar-card{margin:0 32rpx;padding:24rpx}.calendar-nav{align-items:center;display:flex;justify-content:space-between;margin-bottom:24rpx}.calendar-nav__arrow{color:#5d000a;font-size:48rpx;padding:0 16rpx}.calendar-nav__title{color:#5d000a;font-size:32rpx;font-weight:700}.calendar-weekdays{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:8rpx}.calendar-weekdays__item{color:#8b716f;font-size:20rpx;padding:8rpx 0;text-align:center}.calendar-grid{display:grid;grid-gap:4rpx;gap:4rpx;grid-template-columns:repeat(7,1fr)}.calendar-day{align-items:center;aspect-ratio:1;border-radius:8rpx;display:flex;flex-direction:column;justify-content:center;position:relative}.calendar-day--highlight{background-color:rgba(93,0,10,.05);border:2rpx solid #5d000a}.calendar-day__num{color:#1f1c0b;font-size:26rpx}.calendar-day--highlight .calendar-day__num{color:#5d000a;font-weight:700}.calendar-day__dot{background-color:#81131a;border-radius:4rpx;height:8rpx;margin-top:4rpx;width:8rpx}.program-list{padding:0 32rpx}.program-list__month{color:#8b716f;display:block;font-size:28rpx;margin:24rpx 0 12rpx}.program-entry{border-bottom:2rpx solid #ebe2c8;display:flex;gap:20rpx;padding:20rpx 0}.program-entry__date{align-items:center;display:flex;flex-direction:column;flex-shrink:0;width:80rpx}.program-entry__day{color:#5d000a;font-size:36rpx;font-weight:700}.program-entry__weekday{color:#8b716f;font-size:18rpx}.program-entry__info{display:flex;flex:1;flex-direction:column;justify-content:center}.program-entry__title{color:#5d000a;display:block;font-size:26rpx;font-weight:700;text-transform:uppercase}.program-entry__theater{color:#8b716f;display:block;font-size:22rpx;margin-top:4rpx}.program-empty{padding:64rpx 32rpx;text-align:center}.program-empty__icon{display:block;font-size:64rpx;margin-bottom:16rpx}.program-empty__text{color:#8b716f;font-size:24rpx}