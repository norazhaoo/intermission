.custom-tab-bar{background-color:#fff9ed;border-top:2rpx solid #ebe2c8;bottom:0;left:0;padding-bottom:env(safe-area-inset-bottom);position:fixed;right:0;z-index:999}.custom-tab-bar__inner{align-items:center;display:flex;height:110rpx;justify-content:space-around;padding:8rpx 16rpx}.custom-tab-bar__item{align-items:center;display:flex;flex:1;flex-direction:column;justify-content:center;position:relative}.custom-tab-bar__icon-wrap{align-items:center;border-radius:26rpx;display:flex;height:52rpx;justify-content:center;transition:background-color .2s ease;width:80rpx}.custom-tab-bar__icon-wrap--active{background-color:#ffdea5}.custom-tab-bar__icon{font-size:36rpx;line-height:1}.custom-tab-bar__label{color:#8b716f;font-family:Manrope,sans-serif;font-size:18rpx;font-weight:500;letter-spacing:1rpx;margin-top:4rpx;opacity:.7;text-align:center}.custom-tab-bar__label--active{color:#5d000a;font-weight:700;opacity:1}